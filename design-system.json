{
  "$schema": "./design-system.schema.json",
  "name": "Fudomore Design System",
  "description": "Design system for the Fudomore food and beverage delivery application - Light Theme",
  "version": "1.1.1",
  "theme": "light",
  "colors": {
    "text": {
      "main": {
        "general": "#424242",
        "subtle": "#616161",
        "subtlest": "#9e9e9e"
      },
      "white": {
        "general": "#ffffff"
      },
      "inverse": {
        "general": "#ffffff"
      },
      "black": {
        "general": "#000000"
      }
    },
    "icon": {
      "main": {
        "general": "#424242",
        "subtle": "#616161"
      },
      "inverse": {
        "general": "#ffffff",
        "pale": "#616161"
      },
      "black": {
        "general": "#000000"
      }
    },
    "surface": {
      "general": "#ffffff",
      "subtle": "#eeeeee",
      "strong": "#ffffff"
    },
    "statusBar": {
      "main": "#fafafa"
    },
    "card": {
      "container": "#ffffff"
    },
    "searchBar": {
      "container": "#eeeeee"
    },
    "avatars": {
      "general": {
        "container": "#bdbdbd",
        "stroke": "#9e9e9e"
      }
    },
    "imageStroke": {
      "subtle": "rgba(0, 0, 0, 0.04)"
    },
    "divider": {
      "main": {
        "subtle": "rgba(0, 0, 0, 0.15)"
      }
    },
    "chips": {
      "main": {
        "container": {
          "default": "#000000",
          "selected": "#ffffff"
        },
        "stroke": {
          "default": "#eeeeee",
          "selected": "#424242"
        }
      }
    },
    "button": {
      "filled": {
        "main": {
          "general": "#000000"
        }
      },
      "iconFilled": {
        "inverse": {
          "general": {
            "container": {
              "default": "#ffffff"
            }
          },
          "subtlest": {
            "container": {
              "default": "#eeeeee"
            }
          }
        }
      }
    },
    "badge": {
      "points": {
        "innerContainer": {
          "default": "rgba(255, 255, 255, 0.6)"
        }
      },
      "common": {
        "main": {
          "container": "rgba(0, 0, 0, 0.08)"
        }
      }
    },
    "tabBar": {
      "border": "#eeeeee"
    },
    "categorySelected": {
      "text": "#00704a"
    }
  },
  "typography": {
    "fontFamilies": {
      "chinese": {
        "primary": "Noto Sans TC",
        "fallback": "sans-serif"
      },
      "english": {
        "primary": "Poppins",
        "fallback": "sans-serif"
      }
    },
    "chinese": {
      "title": {
        "h1Bold": {
          "fontFamily": "Noto Sans TC",
          "fontStyle": "Medium",
          "fontSize": "20px",
          "fontWeight": 600,
          "lineHeight": 1,
          "letterSpacing": "0px"
        },
        "h2Bold": {
          "fontFamily": "Noto Sans TC",
          "fontStyle": "Medium",
          "fontSize": "16px",
          "fontWeight": 600,
          "lineHeight": 1,
          "letterSpacing": "0px"
        }
      },
      "body": {
        "b1Regular": {
          "fontFamily": "Noto Sans TC",
          "fontStyle": "Regular",
          "fontSize": "14px",
          "fontWeight": 400,
          "lineHeight": 1.5,
          "letterSpacing": "0px"
        },
        "b1Bold": {
          "fontFamily": "Noto Sans TC",
          "fontStyle": "Medium",
          "fontSize": "14px",
          "fontWeight": 600,
          "lineHeight": 1.5,
          "letterSpacing": "0px"
        },
        "b2Regular": {
          "fontFamily": "Noto Sans TC",
          "fontStyle": "Regular",
          "fontSize": "12px",
          "fontWeight": 400,
          "lineHeight": 1.5,
          "letterSpacing": "0px"
        },
        "b2Bold": {
          "fontFamily": "Noto Sans TC",
          "fontStyle": "Medium",
          "fontSize": "12px",
          "fontWeight": 600,
          "lineHeight": 1.5,
          "letterSpacing": "0px"
        },
        "b3Regular": {
          "fontFamily": "Noto Sans TC",
          "fontStyle": "Regular",
          "fontSize": "11px",
          "fontWeight": 400,
          "lineHeight": 1.5,
          "letterSpacing": "0px"
        }
      }
    },
    "english": {
      "body": {
        "b1Regular": {
          "fontFamily": "Poppins",
          "fontStyle": "Regular",
          "fontSize": "14px",
          "fontWeight": 400,
          "lineHeight": 1.5,
          "letterSpacing": "0px"
        },
        "b1Bold": {
          "fontFamily": "Poppins",
          "fontStyle": "SemiBold",
          "fontSize": "14px",
          "fontWeight": 600,
          "lineHeight": 1.5,
          "letterSpacing": "0px"
        }
      }
    }
  },
  "spacing": {
    "baseUnit": {
      "0": "0px",
      "100": "8px",
      "150": "12px",
      "200": "16px"
    }
  },
  "borderRadius": {
    "inputFields": {
      "l": "24px"
    },
    "card": {
      "m": "20px"
    },
    "badge": {
      "capsule": "20px"
    },
    "components": {
      "avatar": "120px",
      "chips": "24px"
    }
  },
  "effects": {
    "shadows": {
      "card": {
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "4px",
        "spread": "0px",
        "color": "rgba(0, 0, 0, 0.05)"
      }
    }
  },
  "components": {
    "avatar": {
      "size": "120px"
    },
    "chips": {
      "height": "24px"
    }
  },
  "dimensions": {
    "image": {
      "l": "12px"
    }
  }
}
